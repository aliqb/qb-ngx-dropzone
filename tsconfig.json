{
  "compileOnSave": false,

  "compilerOptions": {
    "baseUrl": "./",
    "importHelpers": true,
    "module": "es2020",
    "esModuleInterop": true,
    "outDir": "./dist/out-tsc",
    "sourceMap": true,
    "declaration": false,
    "moduleResolution": "bundler",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "target": "ES2022",
    "typeRoots": [
      "node_modules/@types"
    ],
    "paths": {
      "ngx-dropzone": [
        "dist/ngx-dropzone"
      ],
      "ngx-dropzone/*": [
        "dist/ngx-dropzone/*"
      ]
    },
    "useDefineForClassFields": false
  }
}
